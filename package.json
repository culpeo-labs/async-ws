{
  "name": "@culpeo/async-ws",
  "version": "1.1.0",
  "description": "Promise-first WebSocket client for Node.js and browsers",
  "author": "Gerardo Lecaros",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "keywords": [
    "websocket",
    "ws",
    "async",
    "promise",
    "browser",
    "node",
    "client",
    "async-iterator",
    "cross-platform"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/culpeo-labs/async-ws.git"
  },
  "homepage": "https://github.com/culpeo-labs/async-ws#readme",
  "bugs": {
    "url": "https://github.com/culpeo-labs/async-ws/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser/index.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    },
    "./iife": {
      "default": "./dist/iife/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:browser": "xvfb-run vitest run --config vitest.config.browser.mts",
    "build": "rollup -c",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/ws": "^8.5.12",
    "@vitest/browser-playwright": "^4.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.0.1",
    "rollup": "^4.24.0",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
