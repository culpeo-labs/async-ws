{
  "name": "ws-lib",
  "version": "0.1.0",
  "description": "Cross-platform imperative WebSocket client for browser and Node.js",
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "import": "./dist/browser/index.js",
        "default": "./dist/iife/index.js"
      },
      "import": {
        "default": "./dist/esm/index.js"
      },
      "require": {
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "scripts": {
    "test": "vitest run",
    "build": "rollup -c",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/ws": "^8.5.12",
    "rimraf": "^6.0.1",
    "rollup": "^4.24.0",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
